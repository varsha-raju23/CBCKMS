PORT=5001
FRONTEND_URL=https://your-app-name.azurewebsites.net

JWT_SECRET=replace_with_strong_secret

AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=your_database_name
AZURE_SQL_USER=your_sql_username
AZURE_SQL_PASSWORD=replace_with_password

AZURE_STORAGE_CONNECTION_STRING=replace_with_storage_connection_string
AZURE_STORAGE_CONTAINER=tunnel-documents

AZURE_COMMUNICATION_CONNECTION_STRING=replace_with_acs_connection_string
ACS_SENDER_EMAIL=DoNotReply@your-domain.com

GEMINI_API_KEY=replace_with_gemini_api_key

AZURE_SUPER_ADMIN_FULLNAME=System Administrator
AZURE_SUPER_ADMIN_EMAIL=admin@tunnelkms.com
AZURE_SUPER_ADMIN_PASSWORD=replace_with_admin_password
AZURE_SUPER_ADMIN_ORGANIZATION=TunnelKMS

MAX_FILE_SIZE=52428800